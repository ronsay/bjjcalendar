<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="bjjcalendar">
  <description>BJJ Calendar</description>

  <rule ref="category/java/errorprone.xml/JumbledIncrementer"/>
  <rule ref="category/java/codestyle.xml/ForLoopShouldBeWhileLoop"/>
  <rule ref="category/java/errorprone.xml/UnnecessaryConversionTemporary"/>
  <rule ref="category/java/errorprone.xml/OverrideBothEqualsAndHashcode"/>
  <rule ref="category/java/errorprone.xml/ReturnFromFinallyBlock"/>
  <rule ref="category/java/codestyle.xml/UnnecessaryReturn"/>
  <rule ref="category/java/bestpractices.xml/PrimitiveWrapperInstantiation"/>
  <rule ref="category/java/errorprone.xml/ClassCastExceptionWithToArray"/>
  <rule ref="category/java/errorprone.xml/AvoidDecimalLiteralsInBigDecimalConstructor"/>
  <rule ref="category/java/errorprone.xml/UselessOperationOnImmutable"/>
  <rule ref="category/java/performance.xml/BigIntegerInstantiation"/>
  <rule ref="category/java/errorprone.xml/AvoidUsingOctalValues"/>
  <rule ref="category/java/bestpractices.xml/AvoidUsingHardCodedIP"/>
  <rule ref="category/java/errorprone.xml/AvoidMultipleUnaryOperators"/>
  <rule ref="category/java/errorprone.xml/UnconditionalIfStatement"/>
  <rule ref="category/java/errorprone.xml/UnusedNullCheckInEquals"/>

  <rule ref="category/java/errorprone.xml/SuspiciousOctalEscape"/>
  <rule ref="category/java/multithreading.xml/AvoidUsingVolatile"/>
  <rule ref="category/java/codestyle.xml/AvoidUsingNativeCode"/>
  <rule ref="category/java/errorprone.xml/DoNotCallGarbageCollectionExplicitly"/>
  <rule ref="category/java/bestpractices.xml/LooseCoupling"/>
  <rule ref="category/java/design.xml/SimplifyBooleanReturns"/>
  <rule ref="category/java/design.xml/SimplifyBooleanExpressions"/>
  <rule ref="category/java/bestpractices.xml/NonExhaustiveSwitch"/>
  <rule ref="category/java/performance.xml/OptimizableToArrayCall"/>
  <rule ref="category/java/errorprone.xml/EqualsNull"/>
  <rule ref="category/java/errorprone.xml/CompareObjectsWithEquals"/>
  <rule ref="category/java/codestyle.xml/UnnecessaryLocalBeforeReturn"/>
  <rule ref="category/java/errorprone.xml/ImplicitSwitchFallThrough"/>
  <rule ref="category/java/bestpractices.xml/DefaultLabelNotLastInSwitch"/>
  <rule ref="category/java/design.xml/SimplifyConditional"/>
  <rule ref="category/java/bestpractices.xml/LiteralsFirstInComparisons" />
  <rule ref="category/java/codestyle.xml/AvoidProtectedMethodInFinalClassNotExtending"/>
  <rule ref="category/java/codestyle.xml/FieldDeclarationsShouldBeAtStartOfClass"/>
  <rule ref="category/java/performance.xml/AddEmptyString"/>
  <rule ref="category/java/errorprone.xml/SuspiciousEqualsMethodName"/>
  <rule ref="category/java/errorprone.xml/SuspiciousHashcodeMethodName"/>
  <rule ref="category/java/errorprone.xml/UseEqualsToCompareStrings"/>
  <rule ref="category/java/performance.xml/StringInstantiation"/>
  <rule ref="category/java/performance.xml/StringToString"/>
  <rule ref="category/java/codestyle.xml/ControlStatementBraces">
    <properties>
      <property name="checkIfElseStmt" value="true" /> <!-- replaces IfElseStmtsMustUseBraces -->
      <property name="checkSingleIfStmt" value="true" /> <!-- replaces IfStmtsMustUseBraces -->
      <property name="checkWhileStmt" value="true" /> <!-- replaces WhileLoopsMustUseBraces -->
      <property name="checkForStmt" value="true" /> <!-- replaces ForLoopsMustUseBraces -->
      <property name="checkDoWhileStmt" value="true" />
      <property name="checkCaseStmt" value="false" />
      <property name="allowEmptyLoop" value="false" />
    </properties>
  </rule>

  <!-- ============================================================ -->
  <!-- Sonar code smells — design / complexity                      -->
  <!-- ============================================================ -->

  <!-- Cyclomatic complexity: threshold 10 (Sonar default value) -->
  <rule ref="category/java/design.xml/CyclomaticComplexity">
    <properties>
      <property name="classReportLevel" value="80"/>
      <property name="methodReportLevel" value="10"/>
    </properties>
  </rule>

  <!-- Cognitive complexity (PMD 7+, equivalent to Sonar "Cognitive Complexity") -->
  <rule ref="category/java/design.xml/CognitiveComplexity">
    <properties>
      <property name="reportLevel" value="15"/>
    </properties>
  </rule>

  <!-- NPath: number of distinct execution paths -->
  <rule ref="category/java/design.xml/NPathComplexity">
    <properties>
      <property name="reportLevel" value="200"/>
    </properties>
  </rule>

  <!-- Class/method size (NCSS) -->
  <rule ref="category/java/design.xml/NcssCount">
    <properties>
      <property name="classReportLevel" value="1000"/>
      <property name="methodReportLevel" value="60"/>
    </properties>
  </rule>

  <!-- Too many fields in a class (> 15) -->
  <rule ref="category/java/design.xml/ExcessivePublicCount">
    <properties>
      <property name="minimum" value="45"/>
    </properties>
  </rule>

  <!-- Too many methods in a class (> 25) -->
  <rule ref="category/java/design.xml/TooManyMethods">
    <properties>
      <property name="maxmethods" value="25"/>
    </properties>
  </rule>

  <!-- Too many fields in a class (> 15) -->
  <rule ref="category/java/design.xml/TooManyFields">
    <properties>
      <property name="maxfields" value="15"/>
    </properties>
  </rule>

  <!-- God Class (class that does too many things) -->
  <rule ref="category/java/design.xml/GodClass">
    <properties>
      <property name="violationSuppressXPath"
                value=".[pmd-java:typeIs('com.onsayit.bjjcalendar.infrastructure.read.ajp.AjpCalendarExtractor')]"/>
    </properties>
  </rule>

  <!-- Excessive coupling -->
  <rule ref="category/java/design.xml/ExcessiveImports">
    <properties>
      <property name="minimum" value="30"/>
    </properties>
  </rule>

  <!-- Too many parameters (> 7) -->
  <rule ref="category/java/design.xml/ExcessiveParameterList">
    <properties>
      <property name="minimum" value="7"/>
    </properties>
  </rule>

  <!-- Unnecessarily complex method -->
  <rule ref="category/java/design.xml/AvoidDeeplyNestedIfStmts">
    <properties>
      <property name="problemDepth" value="3"/>
    </properties>
  </rule>

  <!-- Collapse: unnecessary nested if/else -->
  <rule ref="category/java/design.xml/CollapsibleIfStatements"/>

  <!-- Use the least derived signature possible -->
  <rule ref="category/java/design.xml/UselessOverridingMethod"/>

  <!-- ============================================================ -->
  <!-- Sonar code smells — dead code / unused                       -->
  <!-- ============================================================ -->

  <rule ref="category/java/bestpractices.xml/UnusedPrivateField"/>
  <rule ref="category/java/bestpractices.xml/UnusedLocalVariable"/>
  <rule ref="category/java/bestpractices.xml/UnusedFormalParameter"/>

  <!-- ============================================================ -->
  <!-- Sonar code smells — general maintainability                  -->
  <!-- ============================================================ -->

  <!-- Avoid empty catch blocks -->
  <rule ref="category/java/errorprone.xml/EmptyCatchBlock"/>


  <!-- Avoid unused imports (redundant with Checkstyle, double safety) -->
  <rule ref="category/java/bestpractices.xml/UnusedAssignment"/>

</ruleset>
